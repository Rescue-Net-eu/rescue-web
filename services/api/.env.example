# API configuration (manual section 18.6). Copy to .env for local dev.
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://rescuenet:rescuenet@localhost:5432/rescuenet
REDIS_URL=redis://localhost:6379/0
JWT_ISSUER=
JWT_AUDIENCE=
OIDC_JWKS_URL=
# Local JWT signing secret (HS256). Set a strong value (>= 32 chars) outside dev.
JWT_SECRET=dev-insecure-change-me-please-set-a-real-secret
# Developer login/token endpoints. Must be false in production.
AUTH_DEV_LOGIN=true
ALLOWED_ORIGINS=http://localhost:3000
S3_ENDPOINT=
S3_BUCKET=
